  notes           String?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
}

model VendorInvoice {
  id            String   @id @default(cuid())
  vendorId      String
  invoiceNumber String
  poNumber      String?
  totalAmount   Decimal  @db.Decimal(12, 2)
  dueDate       DateTime?
  status        String   @default("PENDING")
  matchStatus   String   @default("UNMATCHED")
  notes         String?
  fileUrl       String?
  locationId    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@unique([vendorId, invoiceNumber])
  @@index([vendorId])
  @@index([status])
  @@index([matchStatus])
}

model VendorClaim {
  id          String   @id @default(cuid())
  vendorId    String
  type        String
  description String
  amount      Decimal? @db.Decimal(12, 2)
  status      String   @default("OPEN")
  resolvedAt  DateTime?
  resolvedBy  String?
  resolution  String?
  attachments String[]
  locationId  String
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([status])
}

// ============================================================
// COLLECTIONS
// ============================================================

model CollectionAccount {
  id                     String           @id @default(cuid())
  customerId             String
  collectorId            String?
  status                 CollectionStatus @default(ACTIVE)
  currentBalance         Decimal          @db.Decimal(12, 2)
  agingCurrent           Decimal          @default(0) @db.Decimal(12, 2)
  aging30                Decimal          @default(0) @db.Decimal(12, 2)
  aging60                Decimal          @default(0) @db.Decimal(12, 2)
  aging90                Decimal          @default(0) @db.Decimal(12, 2)
  aging120Plus           Decimal          @default(0) @db.Decimal(12, 2)
  lastContactDate        DateTime?
  lastPaymentDate        DateTime?
  nextActionDate         DateTime?
  nextActionNote         String?
  promiseReliabilityScore Decimal?        @db.Decimal(3, 2)
  holdRecommended        Boolean          @default(false)
  holdReason             String?
  internalMemo           String?
  locationId             String
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  customer  Customer        @relation(fields: [customerId], references: [id])
  promises  PromiseToPay[]
  disputes  Dispute[]
  callLogs  CollectionActivity[]
  payments  PaymentPlan[]

  @@unique([customerId])
  @@index([collectorId])
  @@index([status])
  @@index([locationId])
  @@index([nextActionDate])
}

model CollectionActivity {
  id              String   @id @default(cuid())
  accountId       String
  type            String
  direction       String?
  contactMethod   String?
  outcome         String?
  notes           String?
  followUpDate    DateTime?
  promiseAmount   Decimal? @db.Decimal(12, 2)
  createdBy       String
  createdAt       DateTime @default(now())

  account CollectionAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([createdAt])
}

model PromiseToPay {
  id              String        @id @default(cuid())
  accountId       String
  customerId      String
  amount          Decimal       @db.Decimal(12, 2)
  promiseDate     DateTime
  status          PromiseStatus @default(PENDING)
  paymentReceived Decimal?      @db.Decimal(12, 2)
  receivedDate    DateTime?
  notes           String?
  createdBy       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  account CollectionAccount @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([promiseDate])
  @@index([status])
}

model Dispute {
  id          String        @id @default(cuid())
  accountId   String
  customerId  String
  invoiceId   String?
  amount      Decimal       @db.Decimal(12, 2)
  reason      String
  status      DisputeStatus @default(OPEN)
  ownerId     String?
  resolvedAt  DateTime?
  resolution  String?
  notes       String?
  attachments String[]
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  account CollectionAccount @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([status])
  @@index([ownerId])
}

model PaymentPlan {
  id              String   @id @default(cuid())
  accountId       String
  customerId      String
  totalAmount     Decimal  @db.Decimal(12, 2)
  installments    Int
  frequency       String   @default("MONTHLY")
  startDate       DateTime
  status          String   @default("ACTIVE")
  paidAmount      Decimal  @default(0) @db.Decimal(12, 2)
  nextPaymentDate DateTime?
  notes           String?
  approvedBy      String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account CollectionAccount @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([status])
}

// ============================================================
