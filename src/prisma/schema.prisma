  @@index([assignedTo])
  @@index([locationId])
  @@index([deletedAt])
}

model Estimate {
  id               String         @id @default(cuid())
  estimateNumber   String         @unique
  customerId       String?
  leadId           String?
  salesRepId       String
  jobName          String?
  jobAddress       String?
  status           EstimateStatus @default(DRAFT)
  totalAmount      Decimal        @db.Decimal(12, 2)
  marginPercent    Decimal?       @db.Decimal(5, 2)
  expiresAt        DateTime?
