// ============================================================
// Express Lumber Ops - Database Schema
// Phase 1B: Platform Core Models and Enums
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum PermissionAction {
  VIEW
  CREATE
  EDIT
  DELETE
  APPROVE
  OVERRIDE
  EXPORT
  ADMIN
}

enum ScopeType {
  ALL
  BRANCH
  OWN
  TEAM
  ASSIGNED
  READ_ONLY
}

enum FlagState {
  ON
  OFF
  BETA
  READ_ONLY
  HIDDEN
}

enum FlagLevel {
  COMPANY
  BRANCH
  ROLE
  USER
  ENVIRONMENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED
  ESCALATED
  CANCELLED
}

enum ExceptionSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ExceptionStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  ESCALATED
  DISMISSED
}

enum SecurityEventType {
  LOGIN
  LOGOUT
  FAILED_LOGIN
  PASSWORD_CHANGE
  PASSWORD_RESET
  ROLE_CHANGE
  PERMISSION_CHANGE
  FEATURE_FLAG_CHANGE
  SENSITIVE_ACCESS
  EXPORT
  IMPERSONATION
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  firstName          String
  lastName           String
  phone              String?
  avatarUrl          String?
  status             UserStatus @default(PENDING)
  lastLoginAt        DateTime?
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  mustChangePassword Boolean   @default(false)
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  createdBy          String?

  // Relations
  profile            UserProfile?
  roleAssignments    UserRoleAssignment[]
  assignedByRoles    UserRoleAssignment[] @relation("AssignedBy")
  revokedByRoles     UserRoleAssignment[] @relation("RevokedBy")
  featureFlagAssignments FeatureFlagAssignment[] @relation("FlagCreatedBy")
  approvalRequests   ApprovalRequest[]    @relation("ApprovalRequester")
  resolvedApprovals  ApprovalRequest[]    @relation("ApprovalResolver")
  auditEvents        AuditEvent[]
  securityEventsActor SecurityEvent[]     @relation("SecurityActor")
  securityEventsTarget SecurityEvent[]    @relation("SecurityTarget")
  exceptionsOwned    Exception[]          @relation("ExceptionOwner")
  exceptionsResolved Exception[]          @relation("ExceptionResolver")
  exceptionsEscalated Exception[]         @relation("ExceptionEscalatedTo")
  orgUnitsHeaded     OrganizationUnit[]   @relation("OrgUnitHead")
  employeeSkills     EmployeeSkill[]
  orgTaskAssignments TaskAssignment[]    @relation("TaskAssignUser")
  coverageGaps       CoverageGap[]      @relation("GapUser")

  @@index([email])
  @@index([status])
  @@index([deletedAt])
}

model UserProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  title             String?
  department        String?
  defaultLocationId String?
  defaultPrinter    String?
  timezone          String    @default("America/New_York")
  locale            String    @default("en-US")

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultLocation   Location? @relation(fields: [defaultLocationId], references: [id])
}

model UserPreference {
  id     String @id @default(cuid())
  userId String
  key    String
  value  Json

  @@unique([userId, key])
  @@index([userId])
}

// ============================================================
// LOCATION (BRANCH)
// ============================================================

model Location {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  address     String
  city        String
  state       String
  zip         String
  phone       String?
  fax         String?
  email       String?
  timezone    String    @default("America/New_York")
  isActive    Boolean   @default(true)
  cutoffTime  String    @default("14:00")
  settings    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  userProfiles      UserProfile[]
  roleAssignments   UserRoleAssignment[]
  branchSettings    BranchSetting[]
  customers         Customer[]          @relation("CustomerLocation")
  approvalPolicies  ApprovalPolicy[]
  approvalRequests  ApprovalRequest[]
  auditEvents       AuditEvent[]
  exceptions        Exception[]
  orgUnits          OrganizationUnit[]   @relation("OrgUnitLocation")
  orgTaskAssignments TaskAssignment[]    @relation("TaskAssignLocation")
  coverageGaps       CoverageGap[]      @relation("GapLocation")
  hiringRequests     HiringRequest[]    @relation("HiringLocation")

  @@index([code])
  @@index([isActive])
}

// ============================================================
// RBAC: ROLES & PERMISSIONS
// ============================================================

model Role {
  id          String    @id @default(cuid())
  name        String    @unique
  displayName String
  description String?
  isSystem    Boolean   @default(false)
  isDefault   Boolean   @default(false)
  department  String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  permissions      RolePermission[]
  userAssignments  UserRoleAssignment[]
}

model Permission {
  id           String           @id @default(cuid())
  code         String           @unique
  name         String
  description  String?
  module       String
  action       PermissionAction
  resourceType String?
  isSystem     Boolean          @default(false)

  // Relations
  rolePermissions RolePermission[]

  @@index([module])
  @@index([code])
}

model RolePermission {
  id                String    @id @default(cuid())
  roleId            String
  permissionId      String
  scopeType         ScopeType @default(ALL)
  scopeValue        String?
  fieldRestrictions Json?
  conditions        Json?

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRoleAssignment {
  id           String    @id @default(cuid())
  userId       String
  roleId       String
  locationId   String?
  isTemporary  Boolean   @default(false)
  expiresAt    DateTime?
  assignedBy   String
  assignedAt   DateTime  @default(now())
  revokedAt    DateTime?
  revokedBy    String?
  reason       String?

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  location     Location? @relation(fields: [locationId], references: [id])
  assigner     User      @relation("AssignedBy", fields: [assignedBy], references: [id])
  revoker      User?     @relation("RevokedBy", fields: [revokedBy], references: [id])

  @@unique([userId, roleId, locationId])
  @@index([userId])
  @@index([roleId])
  @@index([locationId])
}

// ============================================================
// FEATURE FLAGS
// ============================================================

model FeatureFlag {
  id           String    @id @default(cuid())
  code         String    @unique
  name         String
  description  String?
  category     String?
  defaultState FlagState @default(OFF)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignments  FeatureFlagAssignment[]

  @@index([code])
  @@index([category])
}

model FeatureFlagAssignment {
  id        String    @id @default(cuid())
  flagId    String
  level     FlagLevel
  targetId  String
  state     FlagState
  createdBy String
  createdAt DateTime  @default(now())

  flag      FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  creator   User        @relation("FlagCreatedBy", fields: [createdBy], references: [id])

  @@unique([flagId, level, targetId])
  @@index([flagId])
  @@index([level, targetId])
}

// ============================================================
// APPROVAL ENGINE
// ============================================================

model ApprovalPolicy {
  id                String    @id @default(cuid())
  name              String
  description       String?
  actionType        String
  entityType        String?
  requesterRoles    String[]
  approverRoles     String[]
  thresholdField    String?
  thresholdMin      Decimal?  @db.Decimal(12, 2)
  thresholdMax      Decimal?  @db.Decimal(12, 2)
  timeoutHours      Int       @default(24)
  escalationRoles   String[]
  requireReason     Boolean   @default(true)
  requireAttachment Boolean   @default(false)
  isActive          Boolean   @default(true)
  locationId        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  location          Location? @relation(fields: [locationId], references: [id])
  requests          ApprovalRequest[]

  @@index([actionType])
  @@index([isActive])
}

model ApprovalRequest {
  id             String         @id @default(cuid())
  policyId       String
  requesterId    String
  entityType     String
  entityId       String
  status         ApprovalStatus @default(PENDING)
  oldValue       Json?
  newValue       Json?
  reason         String
  attachmentIds  String[]
  locationId     String
  expiresAt      DateTime
  resolvedAt     DateTime?
  resolvedBy     String?
  resolutionNote String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  policy         ApprovalPolicy @relation(fields: [policyId], references: [id])
  requester      User           @relation("ApprovalRequester", fields: [requesterId], references: [id])
  resolver       User?          @relation("ApprovalResolver", fields: [resolvedBy], references: [id])
  location       Location       @relation(fields: [locationId], references: [id])

  @@index([policyId])
  @@index([requesterId])
  @@index([status])
  @@index([entityType, entityId])
  @@index([locationId])
}

// ============================================================
// AUDIT & SECURITY EVENTS
// ============================================================

model AuditEvent {
  id          String    @id @default(cuid())
  actorId     String?
  actorName   String
  action      String
  entityType  String
  entityId    String
  entityName  String?
  locationId  String?
  before      Json?
  after       Json?
  metadata    Json?
  source      String    @default("web")
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime  @default(now())

  actor       User?     @relation(fields: [actorId], references: [id])
  location    Location? @relation(fields: [locationId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([locationId])
  @@index([timestamp])
}

model SecurityEvent {
  id           String            @id @default(cuid())
  type         SecurityEventType
  actorId      String?
  targetUserId String?
  details      Json?
  ipAddress    String?
  userAgent    String?
  success      Boolean
  timestamp    DateTime          @default(now())

  actor        User?             @relation("SecurityActor", fields: [actorId], references: [id])
  targetUser   User?             @relation("SecurityTarget", fields: [targetUserId], references: [id])

  @@index([type])
  @@index([actorId])
  @@index([targetUserId])
  @@index([timestamp])
}

// ============================================================
// EXCEPTION ENGINE
// ============================================================

model Exception {
  id                  String           @id @default(cuid())
  category            String
  severity            ExceptionSeverity
  title               String
  description         String?
  entityType          String
  entityId            String
  entityName          String?
  module              String
  ownerId             String?
  locationId          String
  status              ExceptionStatus  @default(OPEN)
  slaTargetAt         DateTime?
  resolvedAt          DateTime?
  resolvedBy          String?
  resolutionNote      String?
  escalatedAt         DateTime?
  escalatedTo         String?
  priorityScore       Int              @default(0)
  relatedExceptionIds String[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  owner               User?            @relation("ExceptionOwner", fields: [ownerId], references: [id])
  resolver            User?            @relation("ExceptionResolver", fields: [resolvedBy], references: [id])
  escalatedUser       User?            @relation("ExceptionEscalatedTo", fields: [escalatedTo], references: [id])
  location            Location         @relation(fields: [locationId], references: [id])

  @@index([category])
  @@index([severity])
  @@index([status])
  @@index([ownerId])
  @@index([locationId])
  @@index([module])
  @@index([entityType, entityId])
  @@index([slaTargetAt])
  @@index([priorityScore])
}

// ============================================================
// BRANCH SETTINGS
// ============================================================

model BranchSetting {
  id          String   @id @default(cuid())
  locationId  String
  key         String
  value       Json
  category    String
  description String?

  location    Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, key])
  @@index([locationId])
  @@index([category])
}

// ============================================================
// BUSINESS ENUMS (Phase 2A)
// ============================================================

enum CustomerType {
  COMMERCIAL
  RESIDENTIAL
  CONTRACTOR
  GOVERNMENT
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  ON_HOLD
  COD_ONLY
  CLOSED
}

enum ProductStatus {
  ACTIVE
  DISCONTINUED
  SPECIAL_ORDER
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PROBATION
}

// ============================================================
// CUSTOMER
// ============================================================

model Customer {
  id                          String         @id @default(cuid())
  accountNumber               String         @unique
  companyName                 String
  dba                         String?
  type                        CustomerType   @default(COMMERCIAL)
  status                      CustomerStatus @default(ACTIVE)
  creditLimit                 Decimal        @default(0) @db.Decimal(12, 2)
  currentBalance              Decimal        @default(0) @db.Decimal(12, 2)
  paymentTerms                String         @default("NET30")
  taxExempt                   Boolean        @default(false)
  taxId                       String?
  defaultSalesRepId           String?
  billingAddress              Json?
  shippingAddress             Json?
  defaultDeliveryInstructions String?
  communicationPreferences    Json?
  notes                       String?
  erpCustomerId               String?        @unique
  locationId                  String
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt
  deletedAt                   DateTime?
  createdBy                   String

  location           Location            @relation("CustomerLocation", fields: [locationId], references: [id])
  contacts           CustomerContact[]
  tags               CustomerTag[]
  jobsites           CustomerJobsite[]
  orders             Order[]
  collectionAccount  CollectionAccount?

  @@index([accountNumber])
  @@index([companyName])
  @@index([status])
  @@index([locationId])
  @@index([defaultSalesRepId])
  @@index([deletedAt])
}

model CustomerContact {
  id                     String   @id @default(cuid())
  customerId             String
  firstName              String
  lastName               String
  email                  String?
  phone                  String?
  mobile                 String?
  role                   String?
  isPrimary              Boolean  @default(false)
  preferredContactMethod String?
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model CustomerTag {
  id         String   @id @default(cuid())
  customerId String
  tag        String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, tag])
  @@index([tag])
}

model CustomerJobsite {
  id                     String   @id @default(cuid())
  customerId             String
  name                   String
  address                Json
  gateCode               String?
  deliveryInstructions   String?
  contactName            String?
  contactPhone           String?
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ============================================================
// PRODUCT
// ============================================================

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  parentId    String?
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parentId])
}

model Product {
  id              String        @id @default(cuid())
  sku             String        @unique
  name            String
  description     String?
  categoryId      String?
  uom             String
  isRandomLength  Boolean       @default(false)
  weight          Decimal?      @db.Decimal(10, 2)
  currentCost     Decimal       @db.Decimal(10, 4)
  currentSell     Decimal       @db.Decimal(10, 2)
  marginPercent   Decimal?      @db.Decimal(5, 2)
  primaryVendorId String?
  status          ProductStatus @default(ACTIVE)
  minOrderQty     Decimal?      @db.Decimal(10, 2)
  leadTimeDays    Int?
  erpProductId    String?       @unique
  locationId      String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  category        ProductCategory? @relation(fields: [categoryId], references: [id])
  primaryVendor   Vendor?          @relation("PrimaryVendor", fields: [primaryVendorId], references: [id])
  costHistory     ProductCostHistory[]
  vendorPrices    VendorPrice[]
  inventoryBalances InventoryLocationBalance[]
  lengthBalances  InventoryLengthBalance[]
  orderItems      OrderItem[]

  @@index([sku])
  @@index([name])
  @@index([categoryId])
  @@index([primaryVendorId])
  @@index([status])
  @@index([locationId])
  @@index([deletedAt])
}

model ProductCostHistory {
  id          String   @id @default(cuid())
  productId   String
  oldCost     Decimal  @db.Decimal(10, 4)
  newCost     Decimal  @db.Decimal(10, 4)
  changePercent Decimal @db.Decimal(5, 2)
  source      String
  vendorId    String?
  changedBy   String?
  effectiveAt DateTime @default(now())
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([effectiveAt])
}

// ============================================================
// VENDOR
// ============================================================

model Vendor {
  id            String       @id @default(cuid())
  code          String       @unique
  name          String
  paymentTerms  String?
  leadTimeDays  Int?
  status        VendorStatus @default(ACTIVE)
  website       String?
  notes         String?
  address       Json?
  reliabilityScore Decimal?  @db.Decimal(3, 2)
  fillRate      Decimal?     @db.Decimal(5, 2)
  costVolatility Decimal?    @db.Decimal(5, 2)
  erpVendorId   String?      @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  contacts       VendorContact[]
  prices         VendorPrice[]
  primaryProducts Product[]  @relation("PrimaryVendor")
  purchaseOrders PurchaseOrder[]
  invoices       VendorInvoice[]
  claims         VendorClaim[]

  @@index([code])
  @@index([name])
  @@index([status])
  @@index([deletedAt])
}

model VendorContact {
  id        String   @id @default(cuid())
  vendorId  String
  firstName String
  lastName  String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

model VendorPrice {
  id          String   @id @default(cuid())
  vendorId    String
  productId   String
  unitCost    Decimal  @db.Decimal(10, 4)
  minQty      Decimal? @db.Decimal(10, 2)
  leadTimeDays Int?
  effectiveDate DateTime
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor  Vendor  @relation(fields: [vendorId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([vendorId, productId, effectiveDate])
  @@index([vendorId])
  @@index([productId])
  @@index([isActive])
}

// ============================================================
// INVENTORY
// ============================================================

model InventoryLocationBalance {
  id          String   @id @default(cuid())
  productId   String
  locationId  String
  onHand      Decimal  @db.Decimal(10, 2)
  allocated   Decimal  @default(0) @db.Decimal(10, 2)
  available   Decimal  @db.Decimal(10, 2)
  onOrder     Decimal  @default(0) @db.Decimal(10, 2)
  reorderPoint Decimal? @db.Decimal(10, 2)
  binLocation String?
  lastCountDate DateTime?
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, locationId])
  @@index([locationId])
}

model InventoryLengthBalance {
  id          String   @id @default(cuid())
  productId   String
  locationId  String
  length      Decimal  @db.Decimal(10, 2)
  quantity    Decimal  @db.Decimal(10, 2)
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, locationId, length])
  @@index([productId])
  @@index([locationId])
}

// ============================================================
// OPERATIONAL ENUMS (Phase 2A)
// ============================================================

enum OrderType {
  DELIVERY
  PICKUP
  WILL_CALL
  TRANSFER
  RETURN_PICKUP
  VENDOR_DROP_SHIP
}

enum OrderStatus {
  DRAFT
  IMPORTED
  NEEDS_REVIEW
  APPROVED
  ON_CREDIT_HOLD
  WAITING_INVENTORY
  PARTIALLY_READY
  READY
  LOADING
  LOADED
  DISPATCHED
  OUT_FOR_DELIVERY
  DELIVERED
  PICKUP_READY
  PICKED_UP
  REFUSED
  RESCHEDULED
  CANCELLED
  CLOSED
}

enum ItemReadyStatus {
  NOT_READY
  PARTIAL
  READY
  BACKORDERED
  SUBSTITUTED
}

enum TruckType {
  FLATBED
  BOX
  BOOM
  PICKUP
  MOFFETT
}

enum TruckStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OUT_OF_SERVICE
}

enum RouteStatus {
  PLANNING
  READY
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum StopStatus {
  PENDING
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  COMPLETED
  FAILED
  SKIPPED
}

enum StopOutcome {
  DELIVERED
  PARTIAL
  REFUSED
  NO_ANSWER
  SITE_CLOSED
  RESCHEDULED
  DAMAGED
  LEFT_ON_SITE
}

enum PaymentType {
  CASH
  CHECK
  CREDIT_CARD
  OTHER
}

enum PickupStatus {
  WAITING
  CUSTOMER_ARRIVED
  PREPPING
  READY_AT_LANE
  LOADING
  HANDED_OFF
  NO_SHOW
  CANCELLED
}

enum YardTaskType {
  ORDER_PREP
  LOADING
  UNLOADING
  TRANSFER
  RECEIVING
  CYCLE_COUNT
  DAMAGE_INSPECTION
  CLEANUP
}

enum YardTaskStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  BLOCKED
  CANCELLED
}

enum ReceivingStatus {
  IN_PROGRESS
  PENDING_REVIEW
  APPROVED
  REJECTED
  AP_HOLD
}

enum ReceivingLineStatus {
  PENDING
  RECEIVED
  SHORT
  OVER
  DAMAGED
  SUBSTITUTE
  REJECTED
}

// ============================================================
// ORDER
// ============================================================

model Order {
  id                  String      @id @default(cuid())
  orderNumber         String      @unique
  type                OrderType   @default(DELIVERY)
  status              OrderStatus @default(DRAFT)
  customerId          String
  customerPO          String?
  jobsiteName         String?
  deliveryAddress     Json?
  contactName         String?
  contactPhone        String?
  salesRepId          String?
  requestedDate       DateTime
  appointmentFlag     Boolean     @default(false)
  appointmentWindow   String?
  codFlag             Boolean     @default(false)
  codAmount           Decimal?    @db.Decimal(12, 2)
  holdReasons         String[]
  rescheduleReason    String?
  specialInstructions String?
  internalNotes       String?
  routeId             String?
  truckId             String?
  stopSequence        Int?
  readinessPercent    Int         @default(0)
  totalWeight         Decimal?    @db.Decimal(10, 2)
  totalPieces         Int?
  totalAmount         Decimal?    @db.Decimal(12, 2)
  marginPercent       Decimal?    @db.Decimal(5, 2)
  priorityScore       Int         @default(0)
  erpOrderId          String?
  locationId          String
  dispatchedAt        DateTime?
  deliveredAt         DateTime?
  closedAt            DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deletedAt           DateTime?
  createdBy           String

  customer Customer   @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  events   OrderEvent[]

  @@index([orderNumber])
  @@index([customerId])
  @@index([status])
  @@index([requestedDate])
  @@index([locationId])
  @@index([routeId])
  @@index([truckId])
  @@index([salesRepId])
  @@index([deletedAt])
}

model OrderItem {
  id                  String          @id @default(cuid())
  orderId             String
  productId           String
  lineNumber          Int
  description         String
  quantity            Decimal         @db.Decimal(10, 2)
  uom                 String
  unitPrice           Decimal         @db.Decimal(10, 2)
  unitCost            Decimal         @db.Decimal(10, 4)
  extendedPrice       Decimal         @db.Decimal(12, 2)
  length              Decimal?        @db.Decimal(10, 2)
  weight              Decimal?        @db.Decimal(10, 2)
  locationCode        String?
  readyStatus         ItemReadyStatus @default(NOT_READY)
  substitutionAllowed Boolean         @default(false)
  substitutedWith     String?
  issueFlag           Boolean         @default(false)
  issueNote           String?
  notes               String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model OrderEvent {
  id         String   @id @default(cuid())
  orderId    String
  fromStatus String?
  toStatus   String
  reason     String?
  actorId    String?
  actorName  String
  metadata   Json?
  createdAt  DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

// ============================================================
// TRUCK & ROUTE
// ============================================================

model Truck {
  id              String      @id @default(cuid())
  number          String      @unique
  name            String?
  type            TruckType   @default(FLATBED)
  maxWeight       Decimal     @db.Decimal(10, 2)
  maxPieces       Int?
  maxBundles      Int?
  maxLength       Decimal?    @db.Decimal(10, 2)
  axleCount       Int         @default(2)
  hasLiftgate     Boolean     @default(false)
  hasMoffett      Boolean     @default(false)
  status          TruckStatus @default(AVAILABLE)
  currentDriverId String?
  locationId      String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  routes Route[]

  @@index([number])
  @@index([status])
  @@index([locationId])
}

model Route {
  id                  String      @id @default(cuid())
  routeNumber         String      @unique
  date                DateTime    @db.Date
  truckId             String
  driverId            String
  dispatcherId        String
  status              RouteStatus @default(PLANNING)
  departedAt          DateTime?
  completedAt         DateTime?
  totalStops          Int         @default(0)
  completedStops      Int         @default(0)
  totalWeight         Decimal?    @db.Decimal(10, 2)
  totalPieces         Int?
  estimatedMiles      Decimal?    @db.Decimal(10, 1)
  estimatedDuration   Int?
  profitabilityScore  Decimal?    @db.Decimal(5, 2)
  feasibilityScore    Decimal?    @db.Decimal(5, 2)
  routeNotes          String?
  locationId          String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  truck Truck       @relation(fields: [truckId], references: [id])
  stops RouteStop[]

  @@index([routeNumber])
  @@index([date])
  @@index([truckId])
  @@index([driverId])
  @@index([status])
  @@index([locationId])
}

model RouteStop {
  id                    String       @id @default(cuid())
  routeId               String
  orderId               String
  sequence              Int
  address               Json
  customerName          String
  contactName           String?
  contactPhone          String?
  deliveryInstructions  String?
  gateCode              String?
  appointmentWindow     String?
  estimatedArrival      DateTime?
  actualArrival         DateTime?
  estimatedServiceTime  Int?
  status                StopStatus   @default(PENDING)
  outcome               StopOutcome?
  failureReason         String?
  completedAt           DateTime?
  geofenceEntered       Boolean      @default(false)
  geofenceLat           Decimal?     @db.Decimal(10, 7)
  geofenceLng           Decimal?     @db.Decimal(10, 7)

  route          Route           @relation(fields: [routeId], references: [id], onDelete: Cascade)
  deliveryProof  DeliveryProof?
  codCollection  CODCollection?

  @@index([routeId])
  @@index([orderId])
  @@index([status])
}

// ============================================================
// DELIVERY PROOF & COD
// ============================================================

model DeliveryProof {
  id           String   @id @default(cuid())
  stopId       String   @unique
  signatureUrl String?
  signedBy     String?
  photos       String[]
  notes        String?
  gpsLat       Decimal  @db.Decimal(10, 7)
  gpsLng       Decimal  @db.Decimal(10, 7)
